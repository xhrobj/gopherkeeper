# JSON-конфиг Клиента
# Сервер JSON-конфиг не использует: для него достаточно .env и флагов
# CONFIG=configs/client.example.json

# уровень логирования Клиента и Сервера
LOG_LEVEL=info

# aдрес HTTPS API GophKeeper
# Сервер использует его как listen address, Клиент - как адрес подключения
ADDRESS=localhost:8080

# параметры локального PostgreSQL
# Makefile собирает DATABASE_DSN из этих значений и передаёт его Серверу через окружение
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gopherkeeperdb
POSTGRES_USER=gopherkeeper
POSTGRES_PASSWORD=password

# JWT для запуска Сервера
# JWT_SECRET обязателен: сгенерировать `make gen-jwt-secret` и скопировать значение
JWT_SECRET=
JWT_TTL=30m

# серверное шифрование приватных payload'ов записей
# RECORD_MASTER_KEY обязателен: сгенерировать `make gen-record-master-key` и скопировать значение
# RECORD_KEY_ID — открытый идентификатор текущего record master key
# В MVP используется один ключ (без ротации), поэтому значение по умолчанию менять не нужно
RECORD_MASTER_KEY=
# RECORD_KEY_ID=primary

# локальные TLS-файлы для HTTPS
# сгенерировать все три файла: `make gen-tls-certs`

# CA certificate для Клиента: добавляется в trust store для проверки HTTPS-сертификата Сервера
# TLS_CA_CERT=.local/certs/ca.pem

# TLS certificate для Сервера: передаётся Серверу при запуске HTTPS listener
# TLS_SERVER_CERT=.local/certs/server.pem

# TLS private key для Сервера: передаётся Серверу вместе с TLS_SERVER_CERT
# TLS_SERVER_KEY=.local/certs/server-key.pem
